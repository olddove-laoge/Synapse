# Synapse runtime
SYNAPSE_ENV=dev

# LLM: DeepSeek
SYNAPSE_LLM_PROVIDER=deepseek
SYNAPSE_LLM_MODEL=deepseek-chat
SYNAPSE_LLM_API_BASE=https://api.deepseek.com/v1
SYNAPSE_LLM_API_KEY=

# Embedding: Alibaba Cloud (DashScope compatible endpoint) or local BGE
SYNAPSE_EMBEDDING_PROVIDER=aliyun
SYNAPSE_EMBEDDING_MODEL=text-embedding-v3
SYNAPSE_EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
SYNAPSE_EMBEDDING_API_KEY=
# when SYNAPSE_EMBEDDING_PROVIDER=local_bge
SYNAPSE_EMBEDDING_LOCAL_MODEL_PATH=D:/C_data/Synapse/models/models--BAAI--bge-large-zh-v1.5

# Neo4j
SYNAPSE_NEO4J_URI=bolt://localhost:7687
SYNAPSE_NEO4J_USER=neo4j
SYNAPSE_NEO4J_PASSWORD=neo4j
